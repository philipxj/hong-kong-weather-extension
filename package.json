{
  "name": "hong-kong-weather-extension",
  "version": "0.1.9",
  "private": true,
  "license": "MIT",
  "type": "module",
  "engines": {
    "node": ">=20.19.0"
  },
  "scripts": {
    "build": "npm run build:chromium",
    "build:chromium": "vite build && node scripts/build-manifest.mjs",
    "build:firefox": "npm run build:chromium && node scripts/build-firefox.mjs",
    "format": "prettier --check .",
    "lint": "eslint .",
    "package:chromium": "npm run build && node scripts/package-extension.mjs chromium",
    "package:firefox": "npm run build:firefox && node scripts/package-extension.mjs firefox",
    "package:source": "node scripts/package-source.mjs",
    "test": "npm run typecheck && npm run lint && npm run test:unit && npm run test:layout && npm run build",
    "test:unit": "vitest run",
    "test:layout": "playwright test",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.61.1",
    "@types/chrome": "^0.2.0",
    "@types/node": "^26.0.1",
    "eslint": "^10.6.0",
    "prettier": "^3.9.1",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.62.0",
    "vite": "^8.1.0",
    "vitest": "^4.1.9"
  }
}
