{
  "manifest_version": 3,
  "name": "HK Weather Alerts",
  "description": "Compact Hong Kong weather and warning utility using Hong Kong Observatory Open Data.",
  "version": "0.1.0",
  "permissions": ["alarms", "notifications", "storage"],
  "host_permissions": ["https://data.weather.gov.hk/*"],
  "icons": {
    "16": "assets/weather-mark.svg",
    "32": "assets/weather-mark.svg",
    "48": "assets/weather-mark.svg",
    "128": "assets/weather-mark.svg"
  },
  "action": {
    "default_title": "HK Weather Alerts",
    "default_popup": "popup.html",
    "default_icon": {
      "16": "assets/weather-mark.svg",
      "32": "assets/weather-mark.svg",
      "48": "assets/weather-mark.svg",
      "128": "assets/weather-mark.svg"
    }
  },
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "options_page": "options.html"
}
