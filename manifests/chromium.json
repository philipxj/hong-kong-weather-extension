{
  "manifest_version": 3,
  "name": "香港天氣預報",
  "description": "快速查看香港現時天氣、天氣警告、雷達圖、閃電位置及 7 天天氣預報。",
  "version": "0.1.1",
  "permissions": ["alarms", "notifications", "storage"],
  "host_permissions": ["https://data.weather.gov.hk/*", "https://www.hko.gov.hk/*"],
  "icons": {
    "16": "assets/generated/weather-mark-16.png",
    "32": "assets/generated/weather-mark-32.png",
    "48": "assets/generated/weather-mark-48.png",
    "128": "assets/generated/weather-mark-128.png"
  },
  "action": {
    "default_title": "香港天氣預報",
    "default_popup": "popup/index.html",
    "default_icon": {
      "16": "assets/generated/weather-mark-16.png",
      "32": "assets/generated/weather-mark-32.png",
      "48": "assets/generated/weather-mark-48.png",
      "128": "assets/generated/weather-mark-128.png"
    }
  },
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "options_page": "options/index.html"
}
